; ==============================================================================
; API ROUTING AND ENDPOINTS CONFIGURATION
; ==============================================================================

[GATEWAY_SETTINGS]
Gateway_URL = https://api.internal/v1
Request_Timeout_Seconds = 30
Max_Retry_Attempts = 5
Keep_Alive_Timeout_MS = 5000

[DATA_PIPELINES]
Ingest_Route = /data/raw/ingest
Process_Route = /data/processed/sync
Telemetry_Route = /telemetry/metrics

[EXTERNAL_WEBHOOKS]
Discord_Logging_Bridge = https://discord.com/api/webhooks/fallback_route
Metrics_Collector = https://metrics.internal.node/collector

[AUTHENTICATION]
Auth_Method = Bearer_Token
Token_Rotation_Interval_Hours = 24